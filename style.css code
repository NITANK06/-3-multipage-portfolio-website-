
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: Arial, sans-serif;
    line-height: 1.6;
    background: #f4f4f4;
    color: #333;
}

header {
    background: #222;
    color: white;
    padding: 1rem 0;
}

.navbar {
    width: 90%;
    margin: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.nav-links {
    list-style: none;
    display: flex;
    gap: 20px;
}

.nav-links a {
    color: white;
    text-decoration: none;
    font-weight: bold;
}
.nav-links a:hover,
.nav-links a:focus {
    color: #00adb5;
}

.hero {
    text-align: center;
    padding: 100px 20px;
    background: white;
}

.hero h2 {
    font-size: 3rem;
    margin-bottom: 10px;
}

.btn {
    display: inline-block;
    margin-top: 20px;
   padding: 12px 20px;
    background: #00adb5;
    color: white;
    text-decoration: none;
    border-radius: 5px;
    border: none;
    cursor: pointer;
}

.page-section {
    width: 90%;
    max-width: 1000px;
    margin: 40px auto;
    background: white;
    padding: 40px;
    border-radius: 10px;
}

.skills {
    width: 90%;
    margin: 50px auto;
}

.card-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-top: 20px;
}

.card {
    background: white;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

form {
    display: flex;
    flex-direction: column;
    gap: 15px;
  input,
textarea {
    padding: 10px;
    border: 1px solid #ccc;
    border-radius: 5px;
}

footer {
    text-align: center;
    background: #222;
    color: white;
    padding: 15px;
    margin-top: 50px;
}

@media (max-width: 768px) {
    .navbar {
        flex-direction: column;
        gap: 10px;
    }
  .nav-links {
        flex-direction: column;
        align-items: center;
    }

    .hero h2 {
        font-size: 2rem;
    }
}
